WWEBJS_TEST_REMOTE_ID=XXXXXXXXXX@c.us
WWEBJS_TEST_CLIENT_ID=authenticated
WWEBJS_TEST_MD=1

# Inbound webhook forwarding target.
# Default can be local code webhook: http://127.0.0.1:${SERVER_PORT}/webhook/whatsapp-workflow
N8N_WEBHOOK_URL=http://127.0.0.1:3000/webhook/whatsapp-workflow
SERVER_PORT=3000
AUTO_SEND_WEBHOOK_REPLY=true

# AI provider (OpenAI-compatible)
AI_BASE_URL=https://your-openai-compatible-host
AI_API_KEY=sk-xxxxx
AI_MODEL=gpt-5.2-chat-latest
AI_TIMEOUT_MS=30000

# Milvus RAG API (from ../milvus/scripts/serve_rag_api.py)
RAG_API_URL=http://127.0.0.1:18080
RAG_TOP_K=10
